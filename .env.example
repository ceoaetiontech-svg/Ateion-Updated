# Supabase Database (get these from Supabase > Settings > Database)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres?user=your_project_ref&password=your_password
SPRING_DATASOURCE_USERNAME=your_project_ref
SPRING_DATASOURCE_PASSWORD=your_password

# YouTube API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend (Vite)
VITE_API_BASE_URL=https://ateion-updated-1.onrender.com/api
VITE_BACKEND_URL=https://ateion-updated-1.onrender.com

# Optional overrides
# JWT_SECRET=your_jwt_secret
# APP_FRONTEND_URL=http://localhost
# VITE_API_BASE_URL=http://localhost:8080
